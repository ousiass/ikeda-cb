---

<PageLayout title="Journal | Ikeda Senchado">
  <!-- Hero -->
  <section class="max-w-[1280px] mx-auto px-12 pt-32 pb-20 text-center">
    <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em] mb-4 block">Journal</span>
    <h1 class="font-h1 text-h1 text-primary mb-6">Notes from the tea room.</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
      Essays, recipes, and field notes from the growers, brewers, and ceramicists shaping Ikeda Senchado.
    </p>
  </section>

  <!-- Article Grid -->
  <section class="max-w-[1280px] mx-auto px-12 pb-[120px]">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {
        articles.map((article) => (
          <article class="group flex flex-col">
            <a href="#" class="block aspect-[4/5] overflow-hidden mb-6 bg-surface-container">
              <img
                alt=""
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                src={article.image}
              />
            </a>
            <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em] mb-3">
              {article.category}
            </span>
            <h2 class="font-h3 text-h3 text-on-surface mb-3 group-hover:text-secondary transition-colors">
              <a href="#">{article.title}</a>
            </h2>
            <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed mb-4">
              {article.excerpt}
            </p>
            <span class="font-label-sm text-label-sm text-outline uppercase tracking-widest mt-auto">
              {article.date}
            </span>
          </article>
        ))
      }
    </div>
  </section>
</PageLayout>
