---
import PageLayout from '../components/templates/PageLayout.astro';
import Button from '../components/atoms/Button.astro';
import Icon from '../components/atoms/Icon.astro';
import FormField from '../components/atoms/FormField.astro';
---

<PageLayout title="Contact | Ikeda Senchado">
  <!-- Hero Section -->
  <section class="max-w-[1440px] mx-auto px-12 pt-32 pb-20 grid grid-cols-1 md:grid-cols-2 gap-24 items-center">
    <div class="space-y-12">
      <div class="space-y-4">
        <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em]">Connection</span>
        <h1 class="font-h1 text-h1 text-primary max-w-md">Seek tranquility in every conversation.</h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-sm">
          Whether you have a question about our harvest or simply wish to share a moment of stillness, we are
          here to listen.
        </p>
      </div>
      <div class="space-y-8 pt-8 border-t border-outline-variant">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div>
            <h3 class="font-label-sm text-label-sm text-primary uppercase mb-4">Inquiries</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">hello@ikedasenchado.com</p>
            <p class="font-body-md text-body-md text-on-surface-variant">+81 (0) 3 1234 5678</p>
          </div>
          <div>
            <h3 class="font-label-sm text-label-sm text-primary uppercase mb-4">Business Hours</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">Mon — Fri</p>
            <p class="font-body-md text-body-md text-on-surface-variant">09:00 — 17:00 JST</p>
          </div>
        </div>
      </div>
    </div>
    <div class="relative aspect-[4/5] bg-surface-container overflow-hidden">
      <img
        alt=""
        class="object-cover w-full h-full opacity-90 transition-transform duration-700 hover:scale-105"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuByX9SjS3VpyrZat08aEtgsea0dnzfq1FR0C2L9BNSMwKxpaWL3IkENILQMjSD9qAZmXX3akuQB4d_T074MhiswLFDjbRrpsLeyuirfL3Al31f5DDCnAFPKN_PDHzi2ocAcZzSX0Fe8bmdJlVA5MLekxD2feIe8F1L7d1ai5YDuUCCgjIjrxK6eZEFNUu8qs5WFTRa-ydvpWSQR9ZnIOryzU4eiT14lZ_FAkY8HBViVg0ATBTjc9EWw45oItI7v0EG5Yex-0Jiq8Tw"
      />
      <div class="absolute inset-0 bg-primary/5 pointer-events-none"></div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="max-w-[1440px] mx-auto px-12 py-32 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-24">
        <h2 class="font-h2 text-h2 mb-4">Send a Message</h2>
        <p class="font-body-md text-body-md text-on-surface-variant italic">The art of mindful communication.</p>
      </div>
      <form action="#" class="space-y-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <FormField name="name" label="Name" placeholder="Your full name" autocomplete="name" />
          <FormField name="email" type="email" label="Email" placeholder="email@example.com" autocomplete="email" />
        </div>
        <div>
          <label class="font-label-sm text-label-sm text-on-surface-variant uppercase block mb-2">Message</label>
          <textarea
            class="w-full bg-transparent border-0 border-b border-outline-variant py-4 focus:ring-0 focus:border-secondary transition-colors font-body-md text-body-md px-0 resize-none"
            placeholder="How may we assist you in your tea journey?"
            rows="4"></textarea>
        </div>
        <div class="flex justify-center pt-8">
          <Button variant="primary" as="button" type="submit">Submit Inquiry</Button>
        </div>
      </form>
    </div>
  </section>

  <!-- Location/Philosophy Section -->
  <section class="max-w-[1440px] mx-auto px-12 py-32 bg-background">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="md:col-span-2 relative h-[400px] overflow-hidden grayscale contrast-125 opacity-80">
        <img
          alt=""
          class="object-cover w-full h-full"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAUToAzJJWr7-1h72s5yrYavNqrEoJhkmd3Lz4vUOf2bgaB1yTlDJXcNezx1qQ0_uRBaHejHEooxB1rBf1yU7hZuX_cV2oRsvV9DWO3RqJ6veS9v6MpZC3QtBWd__5oSU8adY9KQxwlcIE_dkeRsU1iW4qdWxb8ACPSjNeUz8dMjaaj0VCPnfuf1CYOZfChbkuG9fbnTGvRwgHz_5YIso41by3L3BNSzyNXPADWfNAycoUHmk_TAx_zwEOhgNnjBUvU0Sc9DJJFmq4"
        />
        <div class="absolute inset-0 flex items-center justify-center p-12">
          <div class="bg-white/90 backdrop-blur-sm p-12 max-w-md text-center border border-outline-variant">
            <h3 class="font-h3 text-h3 mb-6">Our Sanctuary</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">
              Located in the heart of Uji, Kyoto, where the mist meets the mountains and history is steeped in
              every cup.
            </p>
          </div>
        </div>
      </div>
      <div class="bg-surface-container-low p-12 flex flex-col justify-center border border-outline-variant">
        <Icon name="location_on" class="text-secondary mb-8 text-4xl" />
        <h3 class="font-label-sm text-label-sm text-primary uppercase mb-4">Mailing Address</h3>
        <address class="not-italic font-body-md text-body-md text-on-surface-variant leading-relaxed">
          12-4 Higashiyama-ku<br />
          Kyoto, 605-0001<br />
          Japan
        </address>
      </div>
    </div>
  </section>
</PageLayout>
