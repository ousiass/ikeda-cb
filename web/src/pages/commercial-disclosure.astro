---
import PageLayout from '../components/templates/PageLayout.astro';
---

<PageLayout title="Commercial Disclosure | Ikeda Senchado">
  <div class="pt-48 pb-32 max-w-4xl mx-auto px-6">
    <!-- Hero Section -->
    <header class="mb-24 text-center">
      <p class="font-label-sm text-label-sm text-outline mb-4 uppercase tracking-[0.3em]">Legal Information</p>
      <h1 class="font-h1 text-h1 text-primary mb-6">Commercial Disclosure</h1>
      <div class="w-12 h-[1px] bg-primary mx-auto"></div>
    </header>

    <!-- Compliance Table -->
    <section class="space-y-0">
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Merchant</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-h3 text-h3 text-primary">Ikeda Senchado Co., Ltd.</div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Representative</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-body-lg text-body-lg text-primary">Kenichi Sato</div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Address</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-body-md text-body-md text-primary leading-relaxed">
          4F Ikeda Aoyama Bldg., 1-2-3 Jingumae,<br />
          Shibuya-ku, Tokyo 150-0001, Japan
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Contact</div>
        <div class="md:col-span-2 mt-2 md:mt-0 space-y-4">
          <div>
            <span class="font-label-sm text-[10px] text-outline block mb-1">PHONE</span>
            <p class="font-body-md text-body-md text-primary">+81 3-1234-5678</p>
            <p class="text-[11px] text-on-surface-variant mt-1 italic">
              Hours: 10:00 AM - 6:00 PM JST (Excluding weekends and holidays)
            </p>
          </div>
          <div>
            <span class="font-label-sm text-[10px] text-outline block mb-1">EMAIL</span>
            <p class="font-body-md text-body-md text-primary border-b border-primary w-fit">
              support@ikedasenchado.jp
            </p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Pricing</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-body-md text-body-md text-primary">
          Prices are as displayed on each product page (inclusive of consumption tax).
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Payment Methods</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-body-md text-body-md text-primary">
          <ul class="list-none space-y-2">
            <li>Credit Card (Visa, Mastercard, American Express, JCB)</li>
            <li>Apple Pay / Google Pay</li>
            <li>Bank Transfer (Pre-payment)</li>
          </ul>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Delivery</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-body-md text-body-md text-primary leading-relaxed">
          Orders are typically dispatched within 3 business days of confirmation. For pre-order items, please
          refer to the delivery schedule specified on the product page.
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 border-b border-neutral-100 py-10">
        <div class="font-label-sm text-label-sm text-outline uppercase md:pt-1">Return Policy</div>
        <div class="md:col-span-2 mt-2 md:mt-0 font-body-md text-body-md text-primary leading-relaxed">
          <p class="mb-4">Returns are generally not accepted unless the product is defective.</p>
          <p>
            In the event of damage during transit or incorrect item delivery, please notify us via email
            within 7 days of arrival. We will provide a replacement at our expense.
          </p>
        </div>
      </div>
    </section>

    <!-- Visual Element -->
    <div class="mt-32 relative h-96 w-full bg-surface">
      <img
        alt=""
        class="w-full h-full object-cover grayscale opacity-20"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuA_MX2CRtCZ14rXFwK8pPvymQN3VbBIQ6mWjEP1fENG5noqvFUB2fe2gGzAQyjhuhjLRHyHBlhdp1H2Ur9wWn38VohnhVIGk0HtIRmgg9Xt0yralhoGyVY3nb8_NQdkSqIOi73x4s7iPK0K60W-XVwkeCvyLyxSr_FSaZbEvcGmay5DHjKiyfZMLPDaD7So0RoPV_Pcz1thIUvFkGsOLlLQUPlcr621QPe6MttIfEg6jxw7BvijZEG76oKRn_ZbVq9IbRgFrtYJ5n8"
      />
      <div class="absolute inset-0 flex items-center justify-center">
        <p class="font-serif italic text-h3 text-neutral-300">The Art of Stillness.</p>
      </div>
    </div>
  </div>
</PageLayout>
