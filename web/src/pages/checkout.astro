---
import PageLayout from '../components/templates/PageLayout.astro';
import Button from '../components/atoms/Button.astro';
import Icon from '../components/atoms/Icon.astro';
import FormField from '../components/atoms/FormField.astro';
import Stepper from '../components/molecules/Stepper.astro';
import SummaryLineItem from '../components/molecules/SummaryLineItem.astro';

const lineItems = [
  {
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDp-eh6Hs9ZnCV6BdJwC1hq_NiC89nCOtTvVozg-Y-rFeuOmkovK78XcEhEMfuLJo-KY1usJ7UDklVgcuZc8bGWcikJMIHicLmzY3-fdkGpWK3ysir1hD_GSSDSEA8L0YMSr1Kasy758_EC_AjApo5UxaceXdPaVjLYrraYtpkiK918cDKt-2IFyivpvcx2zw_qC6aFCFkLtO-QT89P86tg48gFX-OikRoaH2n3IqGfLzX0MN0UiYL62RcTpmMBeFfQjNPpNHqJN30',
    name: 'Ceremonial Grade Matcha',
    meta: '30g Tin',
    price: '$42.00',
    quantity: 1,
  },
  {
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDDlTg01GulZSj9E4EN-bz4t-C185GNg4sPvV7JL0DxpY792x9AYc_Sz1P6S01i2Irtq3K7OsqrTUVSt67WEVIVGJcxDGCuthts1h-kn7dYBc8xPN6jj-S1eMALKkad0WCh1_BwHolKS7vW87vs9xqcwz5D1rHWlx_UhHg3u2PHkSSTKecZFZngsCmCzjKj2web78eASh_i5II_NXGxlJHd-eub1Fbgmp_Tz33NSX_1JgYmVliZij32PkwcJHk00QZIIPbtYHzh0hc',
    name: 'Shigaraki Tea Bowl',
    meta: 'Cloud Grey',
    price: '$120.00',
    quantity: 1,
  },
];
---

<PageLayout title="Checkout | Ikeda Senchado" cartCount={2}>
  <div class="max-w-7xl mx-auto px-12 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <!-- Left Column: Checkout Form -->
      <div class="lg:col-span-7">
        <Stepper
          steps={[
            { label: 'Information', active: true },
            { label: 'Shipping' },
            { label: 'Payment' },
          ]}
        />

        <div class="space-y-12">
          <!-- Contact Section -->
          <section>
            <div class="flex justify-between items-end mb-6">
              <h2 class="font-h3 text-h3">Contact Information</h2>
              <p class="font-label-sm text-label-sm">
                Already have an account? <a class="underline" href="/account/">Log in</a>
              </p>
            </div>
            <div class="space-y-4">
              <FormField name="email" type="email" placeholder="Email address" autocomplete="email" />
              <div class="flex items-center gap-2 mt-2">
                <input
                  class="rounded-none border-outline-variant text-primary focus:ring-0"
                  id="newsletter"
                  type="checkbox"
                />
                <label class="font-body-md text-body-md text-on-surface-variant" for="newsletter">
                  Keep me up to date on news and exclusive offers
                </label>
              </div>
            </div>
          </section>

          <!-- Shipping Section -->
          <section>
            <h2 class="font-h3 text-h3 mb-6">Shipping Address</h2>
            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2">
                <select
                  class="w-full border-0 border-b border-outline-variant bg-transparent py-3 font-body-md text-body-md focus:border-primary appearance-none"
                >
                  <option>United States</option>
                  <option>Japan</option>
                  <option>United Kingdom</option>
                </select>
              </div>
              <FormField name="firstName" placeholder="First name" autocomplete="given-name" />
              <FormField name="lastName" placeholder="Last name" autocomplete="family-name" />
              <FormField
                name="address"
                placeholder="Address"
                autocomplete="address-line1"
                class="col-span-2"
              />
              <FormField
                name="address2"
                placeholder="Apartment, suite, etc. (optional)"
                autocomplete="address-line2"
                class="col-span-2"
              />
              <FormField name="city" placeholder="City" autocomplete="address-level2" />
              <FormField name="zip" placeholder="ZIP code" autocomplete="postal-code" />
            </div>
          </section>

          <!-- Action -->
          <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-6">
            <a class="font-label-sm text-label-sm flex items-center gap-2 group" href="/cart/">
              <Icon name="arrow_back" class="transition-transform group-hover:-translate-x-1" />
              Return to Cart
            </a>
            <Button variant="primary" as="button">Proceed to Shipping</Button>
          </div>
        </div>
      </div>

      <!-- Right Column: Order Summary -->
      <div class="lg:col-span-5">
        <div class="bg-surface p-8 lg:p-12 sticky top-32">
          <h2 class="font-h3 text-h3 mb-8">Order Summary</h2>
          <!-- Products -->
          <div class="space-y-6 pb-8 border-b border-outline-variant">
            {lineItems.map((item) => <SummaryLineItem {...item} variant="compact" />)}
          </div>

          <!-- Totals -->
          <div class="py-8 space-y-4 border-b border-outline-variant">
            <div class="flex justify-between items-center">
              <span class="font-body-md text-on-surface-variant">Subtotal</span>
              <span class="font-body-md">$162.00</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="font-body-md text-on-surface-variant">Shipping</span>
              <span class="font-body-md text-on-surface-variant italic">Calculated at next step</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="font-body-md text-on-surface-variant">Estimated Tax</span>
              <span class="font-body-md">$13.36</span>
            </div>
          </div>
          <div class="pt-8 flex justify-between items-center">
            <span class="font-h3 text-h3">Total</span>
            <div class="text-right">
              <span class="font-label-sm text-on-surface-variant mr-2 uppercase">USD</span>
              <span class="font-h3 text-h3 font-bold">$175.36</span>
            </div>
          </div>

          <!-- Discount Code -->
          <div class="mt-8 flex gap-4">
            <input
              class="flex-1 border-0 border-b border-outline-variant bg-transparent py-3 font-body-md focus:border-primary"
              placeholder="Gift card or discount code"
              type="text"
            />
            <Button variant="outline" as="button" class="px-6 py-3">Apply</Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
