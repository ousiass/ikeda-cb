---
import PageLayout from '../components/templates/PageLayout.astro';
import Button from '../components/atoms/Button.astro';
import Icon from '../components/atoms/Icon.astro';
import SummaryLineItem from '../components/molecules/SummaryLineItem.astro';

const orderItems = [
  {
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDBz0_n3UstGgARavR0LlJ5_FEU0zKTgIoXgav7c-0Kw_ozTf2fhaFswIvcqw_PEOF0iP-Msf2_9_FFXAd08K4bNDwUchqHrP4rO3RG0cDAa04vyC7MOlvEnfUCH4emgnZRX0eOYM1tqlTxPLe4iiX4xeAkJOIz0-xPQZKkqE9RY2Z2v2GfOedpIzhsOECReK5VvNA3KO6XH9TqPGDBeeYfROuRekg_QkBwoA_c7w4qQTDzjazzwnl9X1Uffrq1-PlXf1d3U7dC3mE',
    name: 'Ceremonial Grade Matcha',
    meta: 'Uji, Japan | 40g',
    price: '$48.00',
    quantity: 1,
  },
  {
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDgN2ExcvZKHTy1uua8J9lfq9hH1Hqp3tNPU3uchcxfDYpizQi-ESNjkq2TiPVLqTux2FtK4acke1hS-LIF-acNNIQUhZt0_ITKYgffnA3NsagjM0c2T1EPX7mSwwFaIUS_NtnwZjS4WOI2x1YkVe-CwMFWSg7FKLVgV-5JxOeIzWl1kNN6ElNibOysev_4OB74AE0o5C7pUBEhGOqm21keq0GXHA_ZZ3szZMsnlq4qz2vY95u6dXEPQTNfA-li_H2O2kY4pAyFEoM',
    name: 'Hasami Porcelain Cup',
    meta: 'Matte White | Small',
    price: '$32.00',
    quantity: 2,
  },
];
---

<PageLayout title="Order Confirmation | Ikeda Senchado">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12">
    <!-- Confirmation Hero -->
    <section class="py-[120px] text-center max-w-2xl mx-auto">
      <div class="mb-8 flex justify-center">
        <div
          class="w-16 h-16 rounded-full border border-secondary flex items-center justify-center text-secondary"
        >
          <Icon name="done" class="text-4xl" />
        </div>
      </div>
      <h1 class="font-h1 text-h1 mb-4 text-primary">Thank You</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 italic">
        Your journey with Ikeda Senchado begins. May this tea bring a moment of stillness to your day.
      </p>
      <div class="inline-block px-6 py-2 bg-surface-container border border-outline-variant rounded-none">
        <span class="font-label-sm text-on-surface">ORDER #KD-82910</span>
      </div>
    </section>

    <!-- Order Summary Grid -->
    <section class="mb-[120px]">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <!-- Left: Logistics -->
        <div class="lg:col-span-5 space-y-16">
          <div class="space-y-6">
            <h3 class="font-h3 text-h3 pb-4 border-b border-outline-variant">Shipping Details</h3>
            <div class="space-y-2">
              <p class="font-label-sm uppercase text-on-primary-container">Recipient</p>
              <p class="font-body-md text-on-surface">Eleanor Vance</p>
            </div>
            <div class="space-y-2">
              <p class="font-label-sm uppercase text-on-primary-container">Address</p>
              <p class="font-body-md text-on-surface leading-relaxed">
                422 Serenity Lane<br />
                Kyoto Gardens, CA 90210<br />
                United States
              </p>
            </div>
            <div class="space-y-2">
              <p class="font-label-sm uppercase text-on-primary-container">Delivery Method</p>
              <p class="font-body-md text-on-surface">Carbon Neutral Standard Delivery</p>
            </div>
          </div>
          <div class="p-8 bg-white border border-zinc-100 flex items-start gap-6">
            <Icon name="calendar_today" class="text-secondary" />
            <div>
              <p class="font-label-sm uppercase text-on-primary-container mb-1">Estimated Arrival</p>
              <p class="font-h3 text-h3 text-primary">October 14 — 16</p>
            </div>
          </div>
        </div>

        <!-- Right: Order Content -->
        <div class="lg:col-span-7">
          <h3 class="font-h3 text-h3 pb-4 border-b border-outline-variant mb-8">Summary</h3>
          <div class="space-y-8">
            {orderItems.map((item) => <SummaryLineItem {...item} variant="detail" />)}
          </div>
          <div class="mt-12 pt-8 border-t border-outline-variant space-y-4">
            <div class="flex justify-between font-body-md text-on-surface-variant">
              <span>Subtotal</span>
              <span>$112.00</span>
            </div>
            <div class="flex justify-between font-body-md text-on-surface-variant">
              <span>Shipping</span>
              <span class="uppercase tracking-wider">Complimentary</span>
            </div>
            <div class="flex justify-between font-h3 text-h3 text-primary pt-4">
              <span>Total</span>
              <span>$112.00</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA & Visual -->
    <section class="mb-[120px] grid grid-cols-1 md:grid-cols-2 bg-white border border-zinc-100 overflow-hidden">
      <div class="p-16 flex flex-col justify-center items-start">
        <span class="font-label-sm text-on-primary-container uppercase mb-4 tracking-widest">A Moment of Ma</span>
        <h2 class="font-h2 text-h2 mb-6">Deepen your tea ritual while you wait.</h2>
        <p class="font-body-md text-on-surface-variant mb-10 leading-relaxed max-w-sm">
          Explore our curated journal on the history of the Way of Tea, or discover our newest collection of
          hand-fired ceramics from Gifu.
        </p>
        <Button variant="primary" as="a" href="/collection/">Continue Shopping</Button>
      </div>
      <div class="h-[400px] md:h-auto">
        <img
          class="w-full h-full object-cover"
          alt=""
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuACTumKRhveOps2Wd5jleim9V98EmqycPFQnWvyhXY6Q0FG2Uy8MbEqTtLydlZdvEptHlWytgm6kaqxOSsUweqVDs40kNR89nE1e82oREplKE2blBJPOVBMCmJVXXD2eulKip-ZG7UTSR6bwHK790oRCzEogWrTfS2jJuekRZh_7-La64WKTTJAGBG_NAEYRgAWiLWgwrd29963KKh18Ua2z6mF3do33qS-foiXSM6Aa4fCX4SRb5tZlfpj6ng_7kbhNJcf4DZ8BPA"
        />
      </div>
    </section>
  </div>
</PageLayout>
