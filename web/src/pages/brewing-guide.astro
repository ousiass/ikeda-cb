---
import PageLayout from '../components/templates/PageLayout.astro';
import Stepper from '../components/molecules/Stepper.astro';
import Button from '../components/atoms/Button.astro';

const matchaSteps = [
  { label: 'Step 1' },
  { label: 'Step 2' },
  { label: 'Step 3' },
  { label: 'Step 4' },
];

const senchaSteps = [
  { label: 'Step 1' },
  { label: 'Step 2' },
  { label: 'Step 3' },
];

const hojichaSteps = [
  { label: 'Step 1' },
  { label: 'Step 2' },
  { label: 'Step 3' },
];
---

<PageLayout title="Brewing Guide | Ikeda Senchado">
  <!-- Hero -->
  <section class="max-w-[1280px] mx-auto px-12 pt-32 pb-20 text-center">
    <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em] mb-4 block">Brewing Guide</span>
    <h1 class="font-h1 text-h1 text-primary mb-6">The art of preparation.</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
      A patient cup is the first ritual of the day. Follow these steps from Ikeda Senchado to coax depth, umami,
      and clarity from each leaf.
    </p>
  </section>

  <!-- Matcha Ceremony -->
  <section class="py-[80px] max-w-[1280px] mx-auto px-12 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="aspect-[4/5] overflow-hidden">
      <img
        alt=""
        class="w-full h-full object-cover"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCfqkZoQgBN6wIUPuGhZ1-PMouQ3FmPzTdV05WCmtD1Bs3wEcV1GGQts1tWxyEmONolRcjTRzAFZRvWj5VoDUv0sg-sHNwh2aprRnKKD5UbUtcnwUaTyTAYX8Gle9Dt3cWNLqHFM_GnzMAVoqoFMKKKuDNenNpIwnAxAAQsLTjY_yy288cZgqfKjEHkO9gOjCU4r-xYWmw7UCYRpbEEe_Z8Uxqx_ILfkV1v8ZYmtABrHFpitta_lSh7LgAyOYmCkWBzSRclB1707As"
      />
    </div>
    <div>
      <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em] mb-4 block">Ceremonial</span>
      <h2 class="font-h2 text-h2 text-on-surface mb-6">Matcha Ceremony</h2>
      <Stepper steps={matchaSteps} />
      <ol class="space-y-6">
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">1. Warm the bowl</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            Rinse a wide chawan with hot water, then dry with a clean cloth. A warm vessel preserves temperature.
          </p>
        </li>
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">2. Sift the matcha</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            Sift 2 grams (about one heaping chashaku) of matcha through a fine mesh into the bowl.
          </p>
        </li>
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">3. Add water</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            Pour 70 ml of soft water at 75°C. Never use boiling water; it scorches the leaf.
          </p>
        </li>
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">4. Whisk in W-strokes</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            With a chasen, whisk briskly in a W motion until a fine, uniform foam settles on the surface.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Sencha -->
  <section class="py-[80px] bg-background">
    <div class="max-w-[1280px] mx-auto px-12 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="order-2 md:order-1">
        <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em] mb-4 block">Loose Leaf</span>
        <h2 class="font-h2 text-h2 text-on-surface mb-6">Sencha Brewing</h2>
        <Stepper steps={senchaSteps} />
        <ol class="space-y-6">
          <li>
            <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">1. Measure leaves</h3>
            <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
              Place 5 grams of loose sencha into a kyusu for two cups.
            </p>
          </li>
          <li>
            <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">2. Cool the water</h3>
            <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
              Pour 180 ml of just-boiled water into a yuzamashi to bring it down to 70°C.
            </p>
          </li>
          <li>
            <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">3. Steep and pour</h3>
            <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
              Pour over the leaves, steep 60 seconds, then decant fully. Re-steep up to twice with shorter times.
            </p>
          </li>
        </ol>
      </div>
      <div class="aspect-[4/5] overflow-hidden order-1 md:order-2">
        <img
          alt=""
          class="w-full h-full object-cover"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBWWLuqukJXYrhQEigDaEzi2ie31JH8dRbT9IPA8EiC6b5AN-6C7tTbT-QBozFroyrgAUGFK9HocAyZf82l87zqjKlmoX3T8Yy_f65eWR7lwiZdHapDHfxq0cnbC2yMZl5OTmoI3UThWV3fvXCkv3uxdL6Fk-bl4MiFC1wYobx4qogUqensU3RIMrIfRMJJSi6PzcOop9aPuNxtv0tmBC2ica8Is-38lVn9uH-ISG2JKASncfYuEGNsqKeVah9BODw9o129XFAj248"
        />
      </div>
    </div>
  </section>

  <!-- Hojicha -->
  <section class="py-[80px] max-w-[1280px] mx-auto px-12 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="aspect-[4/5] overflow-hidden">
      <img
        alt=""
        class="w-full h-full object-cover"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuDQfF74QdJZOOqr7BVQGdpy8VhDSryHq-toH4Xnk-AZrnAEE8wGG7_H5-2kT8Y73_x40IOY1gp03Rv8z3tqcvqb17pv23-lDOgZRP48oksrYKzR7lU2BGqrjvy9J8eK74_ZPkdmvitQMmV3cOY7xYo_vokXgs7GrANUurq5MLD7cl_dQrvYNlICy_cZdt6bzmKmliWVy7fa3JF57rh9shC3lxfL6rpQYZWKkjxgc42lyA1ZoMkKJwtBDgaK5KR__7v9Sal7dHhQzlk"
      />
    </div>
    <div>
      <span class="font-label-sm text-label-sm text-secondary uppercase tracking-[0.3em] mb-4 block">Roasted</span>
      <h2 class="font-h2 text-h2 text-on-surface mb-6">Hojicha Brewing</h2>
      <Stepper steps={hojichaSteps} />
      <ol class="space-y-6">
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">1. Generous leaf</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            Hojicha welcomes a heavier hand: use 6 grams of roasted leaf for 250 ml.
          </p>
        </li>
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">2. Boiling water</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            Unlike green teas, hojicha thrives on freshly boiled 95°C water that draws out the deep roast.
          </p>
        </li>
        <li>
          <h3 class="font-label-sm text-label-sm uppercase text-on-surface mb-2">3. Short steep</h3>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            Steep just 30 seconds. The infusion should glow amber, soft on the palate, low in caffeine.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-outline-variant py-[120px] flex flex-col items-center px-8">
    <h3 class="font-h2 text-h2 text-on-surface mb-6 text-center">Find your daily leaf.</h3>
    <Button variant="primary" as="a" href="/collection/">Shop the Collection</Button>
  </section>
</PageLayout>
